#!/usr/bin/env sh
set -e

yarn build

# Keep generated bundle artifacts in the same commit as source changes.
if ! git add dist/index.js dist/licenses.txt; then
	echo "pre-commit: impossible d'ajouter les artefacts générés (dist/index.js, dist/licenses.txt)."
	echo "pre-commit: merci d'exécuter 'git add dist/index.js dist/licenses.txt' puis de relancer le commit."
	exit 1
fi

# If something still remains unstaged for generated files, stop and ask for a new commit.
if ! git diff --quiet -- dist/index.js dist/licenses.txt; then
	echo "pre-commit: des changements générés ne sont pas intégrés au commit."
	echo "pre-commit: merci de faire 'git add dist/index.js dist/licenses.txt' puis de relancer le commit."
	exit 1
fi
